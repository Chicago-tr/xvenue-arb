
PAIRS=BTC-USD,ETH-USD,SOL-USD
DB_URL=postgresql://postgres@localhost:5432/arb
JDBC_URL=jdbc:postgresql://localhost:5432/arb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arb
PJAR=/path/to/postgresql-42.6.0.jar

# Notes:
# - `DB_URL` is used by the TypeScript ingestion service and Dash app.
# - `JDBC_URL` is used by Spark to read/write Postgres tables.
# - `PJAR` should point to your PostgreSQL JDBC driver JAR for Spark.
# - If you use Docker Compose, the service environment and Postgres trust config are already configured.
